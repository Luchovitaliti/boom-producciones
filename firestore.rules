rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════
    // USERS — máxima protección
    // ══════════════════════════════════════════
    match /users/{uid} {
      // Cualquier autenticado puede leer (necesario para cargar USERS, chat avatars, etc.)
      allow read: if request.auth != null;

      // Crear doc propio: solo si es tu UID (bootstrap/migración)
      allow create: if request.auth != null
                    && request.auth.uid == uid;

      // Actualizar doc propio: solo campos de perfil
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['chatName', 'displayName', 'bio', 'instagram',
                                 'telefono', 'photoURL', 'updatedAt']);

      // Delete y cambio de role/pages/email/active: BLOQUEADO desde cliente
      // (se hace via API con Admin SDK que bypassa estas reglas)
      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // CHAT MESSAGES — subcollections
    // ══════════════════════════════════════════
    match /chatChannels/{channelId}/messages/{msgId} {
      allow read: if request.auth != null;
      // Solo puede crear (no editar/borrar), debe incluir su uid
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Chat config (customChannels)
    match /chat/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ══════════════════════════════════════════
    // DATOS FINANCIEROS — solo autenticados
    // ══════════════════════════════════════════
    // Idealmente mover a API, pero por ahora restringir a autenticados
    match /adminfin/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /recaudacion/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /cajas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ══════════════════════════════════════════
    // DATOS OPERATIVOS — autenticados
    // ══════════════════════════════════════════
    match /eventos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /stock/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /gastos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /staff/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /actividad/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /publogs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /beneficios/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /trafic/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Pasajeros subcollection
      match /pasajeros/{pasId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    match /proveedores/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ══════════════════════════════════════════
    // CONTENIDO — autenticados
    // ══════════════════════════════════════════
    match /cm/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /boom/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /publicas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ══════════════════════════════════════════
    // DENY ALL — cualquier otra collection
    // ══════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
