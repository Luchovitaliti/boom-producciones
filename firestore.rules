rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return request.auth != null && userRole() == 'Admin Console';
    }
    function hasRole(r) {
      return request.auth != null && (userRole() == 'Admin Console' || userRole() == r);
    }

    // ══════════════════════════════════════════
    // USERS — máxima protección
    // ══════════════════════════════════════════
    match /users/{uid} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == uid;

      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['chatName', 'displayName', 'bio', 'instagram',
                                 'telefono', 'photoURL', 'updatedAt']);

      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // CHAT MESSAGES — subcollections
    // ══════════════════════════════════════════
    match /chatChannels/{channelId}/messages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /chat/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════
    // FINANCIEROS — solo admin
    // ══════════════════════════════════════════
    match /adminfin/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /recaudacion/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /cajas/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════
    // CONFIG / EVENTOS / PROVEEDORES — solo admin
    // ══════════════════════════════════════════
    match /eventos/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /proveedores/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════
    // PÚBLICAS / ACTIVIDAD / BENEFICIOS — admin o Públicas
    // ══════════════════════════════════════════
    match /publicas/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Públicas');
    }
    match /actividad/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Públicas');
    }
    match /beneficios/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Públicas');
    }
    match /publogs/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Públicas');
    }

    // ══════════════════════════════════════════
    // TRAFIC — admin o Trafic
    // ══════════════════════════════════════════
    match /trafic/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Trafic');

      match /pasajeros/{pasId} {
        allow read: if request.auth != null;
        allow write: if hasRole('Trafic');
      }
    }

    // ══════════════════════════════════════════
    // BARRA — admin o Barra
    // ══════════════════════════════════════════
    match /stock/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Barra');
    }
    match /gastos/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Barra');
    }
    match /staff/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('Barra');
    }

    // ══════════════════════════════════════════
    // CONTENIDO — admin o CM
    // ══════════════════════════════════════════
    match /cm/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('CM');
    }
    match /boom/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('CM');
    }

    // ══════════════════════════════════════════
    // DENY ALL
    // ══════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
